# Network configuration
# IVA hostname and IP address through which the machine running the IVA can be reached
# Example:"116.234.169.95"
EXTERNAL_IP="192.168.100.65"
# Example:"my-hostname"
EXTERNAL_HOSTNAME="192.168.100.65"
# Network which Milestone AI Bridge containers are running on
AIBRIDGE_NETWORK="aibridge_default"

# Define these variables if your vms is not in the network domain
VMS_IP="192.168.101.155"
# VMS_HOSTNAME="<my-management-server-hostname>"

# App configuration
# The port in which the app can be reached
APP_WEBSERVER_PORT="7443"
# The URL prefix to reach the app
APP_URL_PATH="bridge-connectivity-services"
APP_ID="c24cf88c-97b4-4917-9fdb-4279396b0dee"
APP_NAME="Bridge Connectivity Services"
APP_DESCRIPTION="Custom IVA app registered as a separate AI Bridge integration."
MANUFACTURER_NAME="Bridge Services"
ENFORCE_OAUTH="false"
SNAPSHOT_TOPIC_NAME="bridge-snapshot-service"
SNAPSHOT_TOPIC_DESCRIPTION="Open the snapshot service for a selected camera."
ANALYTIC_EVENT_TOPIC_NAME="bridge-analytic-events-service"
ANALYTIC_EVENT_TOPIC_PATH="bridge-analytic-events-service"
ANALYTIC_EVENT_TOPIC_DESCRIPTION="Start or stop analytic event delivery."
ONVIF_TOPIC_NAME="bridge-onvif-metadata-service"
ONVIF_TOPIC_PATH="bridge-onvif-metadata-service"
ONVIF_TOPIC_DESCRIPTION="Start or stop ONVIF metadata delivery."
ONVIF_FRAME_TOPIC_NAME="bridge-onvif-frame-service"
ONVIF_FRAME_TOPIC_PATH="bridge-onvif-frame-service"
ONVIF_FRAME_TOPIC_DESCRIPTION="Start or stop ONVIF frame metadata delivery."
DEEPSTREAM_MINIMAL_TOPIC_NAME="bridge-deepstream-minimal-service"
DEEPSTREAM_MINIMAL_TOPIC_PATH="bridge-deepstream-minimal-service"
DEEPSTREAM_MINIMAL_TOPIC_DESCRIPTION="Start or stop DeepStream minimal metadata delivery."

# Encrypt communication with XProtect using TLS
# When set to true the app will be exposed through https. Otherwise, set to false.
TLS_ENABLED=false
# If the IVA app is configured with certificates use https, otherwise use http.
TLS_SCHEME="http"
